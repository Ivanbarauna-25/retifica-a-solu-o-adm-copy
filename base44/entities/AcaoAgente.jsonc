{
  "name": "AcaoAgente",
  "type": "object",
  "properties": {
    "tipo_acao": {
      "type": "string",
      "enum": [
        "analise_automatica",
        "chat_usuario",
        "correcao_sugerida",
        "relatorio_gerado",
        "erro_investigado",
        "tarefa_criada",
        "patch_aplicado"
      ],
      "description": "Tipo da a\u00e7\u00e3o realizada pelo agente"
    },
    "status": {
      "type": "string",
      "enum": [
        "em_andamento",
        "concluido",
        "falhou",
        "cancelado"
      ],
      "default": "em_andamento",
      "description": "Status da a\u00e7\u00e3o"
    },
    "prioridade": {
      "type": "string",
      "enum": [
        "baixa",
        "media",
        "alta",
        "critica"
      ],
      "default": "media",
      "description": "Prioridade da a\u00e7\u00e3o"
    },
    "erro_relacionado_id": {
      "type": "string",
      "description": "ID do erro relacionado (ErrorLog)"
    },
    "tarefa_relacionada_id": {
      "type": "string",
      "description": "ID da tarefa relacionada (CodeFixTask)"
    },
    "conversa_id": {
      "type": "string",
      "description": "ID da conversa do agente (se aplic\u00e1vel)"
    },
    "descricao": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o detalhada da a\u00e7\u00e3o"
    },
    "resultado": {
      "type": "string",
      "description": "Resultado da a\u00e7\u00e3o (em formato markdown)"
    },
    "contexto": {
      "type": "object",
      "description": "Contexto adicional da a\u00e7\u00e3o (JSON com dados relevantes)"
    },
    "tempo_execucao": {
      "type": "number",
      "description": "Tempo de execu\u00e7\u00e3o em segundos"
    },
    "iniciado_por": {
      "type": "string",
      "enum": [
        "sistema",
        "usuario"
      ],
      "default": "sistema",
      "description": "Quem iniciou a a\u00e7\u00e3o"
    },
    "usuario_id": {
      "type": "string",
      "description": "ID do usu\u00e1rio que iniciou (se aplic\u00e1vel)"
    },
    "data_conclusao": {
      "type": "string",
      "format": "date-time",
      "description": "Data e hora de conclus\u00e3o"
    }
  },
  "required": [
    "tipo_acao",
    "status",
    "descricao"
  ]
}